{
    "configurations": [
        {
            "name": "Containers: Node.js Launch",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-run: debug",
            "platform": "node",
            "node": {
                "package": "${workspaceFolder}/mindtrack-front/package.json",
                "localRoot": "${workspaceFolder}/mindtrack-front"
            }
        },
        {
            "type": "java",
            "name": "Spring Boot-MindtrackapiApplication<mindtrackapi>",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.bernardo.mindtrackapi.MindtrackapiApplication",
            "projectName": "mindtrackapi",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}